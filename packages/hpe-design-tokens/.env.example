# Figma API token (Figma account settings -> Personal access tokens)
PERSONAL_ACCESS_TOKEN=

# Figma file keys (copy from each file URL)
# primitive file key
FILE_KEY_PRIMITIVE=
# semantic file key
FILE_KEY_SEMANTIC=
# component file key
FILE_KEY_COMPONENT=

# Expected remote collection keys used by verifyReferences
# source: GET /v1/files/{file_key}/variables/local -> meta.variableCollections[*].key
FIGMA_COLOR_COLLECTION_KEY=
FIGMA_DIMENSION_COLLECTION_KEY=
FIGMA_PRIMITIVES_COLLECTION_KEY=
FIGMA_GLOBAL_COLLECTION_KEY=
