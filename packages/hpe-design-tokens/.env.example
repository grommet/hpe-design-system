# Environment-scoped sync configuration
#
# Scripts accept --env=production|test
# - production env vars are read from PRODUCTION_* first
# - test env vars are read from TEST_*
# - legacy unscoped names remain supported for production only
#
# Security note:
# - Do not store personal access tokens in this file by default.
# - Prefer loading tokens from a secure secret store (Keychain, 1Password, CI secrets manager)
#   and exporting them at runtime as PRODUCTION_PERSONAL_ACCESS_TOKEN / TEST_PERSONAL_ACCESS_TOKEN.

# Production file keys (non-secret identifiers)
PRODUCTION_FILE_KEY_PRIMITIVE=
PRODUCTION_FILE_KEY_SEMANTIC=
PRODUCTION_FILE_KEY_COMPONENT=

# Production expected remote collection keys
PRODUCTION_FIGMA_COLOR_COLLECTION_KEY=
PRODUCTION_FIGMA_DIMENSION_COLLECTION_KEY=
PRODUCTION_FIGMA_PRIMITIVES_COLLECTION_KEY=
PRODUCTION_FIGMA_GLOBAL_COLLECTION_KEY=

# Test file keys (non-secret identifiers)
TEST_FILE_KEY_PRIMITIVE=
TEST_FILE_KEY_SEMANTIC=
TEST_FILE_KEY_COMPONENT=

# Test expected remote collection keys
TEST_FIGMA_COLOR_COLLECTION_KEY=
TEST_FIGMA_DIMENSION_COLLECTION_KEY=
TEST_FIGMA_PRIMITIVES_COLLECTION_KEY=
TEST_FIGMA_GLOBAL_COLLECTION_KEY=

# Legacy production-only fallback names (optional; non-secrets shown here)
FILE_KEY_PRIMITIVE=
FILE_KEY_SEMANTIC=
FILE_KEY_COMPONENT=
FIGMA_COLOR_COLLECTION_KEY=
FIGMA_DIMENSION_COLLECTION_KEY=
FIGMA_PRIMITIVES_COLLECTION_KEY=
FIGMA_GLOBAL_COLLECTION_KEY=

# Optional legacy token fallback names are intentionally omitted from this example
# to avoid promoting plaintext secret storage in project files.
# If needed for local debugging only, export in your shell session instead.

# CI-only production safety gate for mutating production
ALLOW_PRODUCTION_WRITES=
