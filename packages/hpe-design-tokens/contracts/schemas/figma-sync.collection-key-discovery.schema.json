{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hpe.design/schemas/figma-sync.collection-key-discovery.schema.json",
  "title": "Figma Collection Key Discovery Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "eventType",
    "runId",
    "environment",
    "generatedAt",
    "files",
    "collections",
    "conflicts"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "eventType": {
      "const": "collection-key-discovery"
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "environment": {
      "type": "string",
      "enum": ["production", "test"]
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/fileDiscovery"
      }
    },
    "collections": {
      "type": "object",
      "additionalProperties": false,
      "required": ["color", "dimension", "primitives", "global"],
      "properties": {
        "color": { "$ref": "#/$defs/collectionDiscovery" },
        "dimension": { "$ref": "#/$defs/collectionDiscovery" },
        "primitives": { "$ref": "#/$defs/collectionDiscovery" },
        "global": { "$ref": "#/$defs/collectionDiscovery" }
      }
    },
    "conflicts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/conflict"
      }
    }
  },
  "$defs": {
    "fileTier": {
      "type": "string",
      "enum": ["primitive", "semantic", "component"]
    },
    "collectionName": {
      "type": "string",
      "enum": ["color", "dimension", "primitives", "global"]
    },
    "remoteCollection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "key", "variableCount", "modeNames"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "key": { "type": "string", "minLength": 1 },
        "variableCount": { "type": "integer", "minimum": 0 },
        "modeNames": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "fileDiscovery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tier", "fileKey", "remoteCollections"],
      "properties": {
        "tier": { "$ref": "#/$defs/fileTier" },
        "fileKey": { "type": "string", "minLength": 1 },
        "remoteCollections": {
          "type": "array",
          "items": { "$ref": "#/$defs/remoteCollection" }
        }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "observedInTiers",
        "variableReferenceCount",
        "isConfiguredKey"
      ],
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "observedInTiers": {
          "type": "array",
          "items": { "$ref": "#/$defs/fileTier" },
          "minItems": 1,
          "uniqueItems": true
        },
        "variableReferenceCount": { "type": "integer", "minimum": 0 },
        "isConfiguredKey": { "type": "boolean" }
      }
    },
    "recommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "reason"],
      "properties": {
        "key": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "enum": ["single-candidate", "multiple-candidates", "none-found"]
        }
      }
    },
    "collectionDiscovery": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "collectionName",
        "configuredKey",
        "recommendation",
        "candidates"
      ],
      "properties": {
        "collectionName": { "$ref": "#/$defs/collectionName" },
        "configuredKey": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "recommendation": { "$ref": "#/$defs/recommendation" },
        "candidates": {
          "type": "array",
          "items": { "$ref": "#/$defs/candidate" }
        }
      }
    },
    "conflict": {
      "type": "object",
      "additionalProperties": false,
      "required": ["collectionName", "candidateKeys"],
      "properties": {
        "collectionName": { "$ref": "#/$defs/collectionName" },
        "candidateKeys": {
          "type": "array",
          "minItems": 2,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
